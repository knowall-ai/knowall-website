# Copy this file to .env.local and fill in real values. Never commit secrets.

# OpenAI API key for the Sally chat assistant (/api/chat)
OPENAI_API_KEY=your_openai_api_key_here

# Admin API key for viewing chat logs (/admin/logs)
ADMIN_API_KEY=your_admin_api_key_here

# Optional: override the Nostr npub that receives contact-form messages.
# Defaults to the production KnowAll AI npub when unset. Not a secret —
# npubs are public keys. Useful for pointing the form at a test identity.
# NEXT_PUBLIC_NOSTR_CONTACT_NPUB=npub1...
